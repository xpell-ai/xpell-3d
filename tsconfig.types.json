{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,

   "moduleResolution": "bundler",
    "module": "ESNext",

    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "types", "public", "examples", "example"]
}
